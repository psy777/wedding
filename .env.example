# ===========================================
# Google Sheets API (server-side only)
# ===========================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-here

# ===========================================
# Couple & Date (NEXT_PUBLIC_ = visible to browser)
# ===========================================
NEXT_PUBLIC_PARTNER1=Partner One
NEXT_PUBLIC_PARTNER2=Partner Two
NEXT_PUBLIC_DATE_FULL=Saturday, June 20th, 2026
NEXT_PUBLIC_DATE_SHORT=June 20, 2026
NEXT_PUBLIC_DATE_ISO=2026-06-20
NEXT_PUBLIC_TIME_CEREMONY=4:00 PM
NEXT_PUBLIC_TIME_RECEPTION=5:30 PM

# ===========================================
# Venue
# ===========================================
NEXT_PUBLIC_VENUE_NAME=The Venue Name
NEXT_PUBLIC_VENUE_ADDRESS=123 Venue Street
NEXT_PUBLIC_VENUE_CITY=Austin
NEXT_PUBLIC_VENUE_STATE=TX
NEXT_PUBLIC_VENUE_ZIP=78701
NEXT_PUBLIC_VENUE_MAP_URL=https://maps.google.com/?q=The+Venue+Name+Austin+TX

# ===========================================
# Dress Code & RSVP Deadline
# ===========================================
NEXT_PUBLIC_DRESS_CODE=Semi-formal / Cocktail Attire
NEXT_PUBLIC_RSVP_DEADLINE_DISPLAY=May 15, 2026
NEXT_PUBLIC_RSVP_DEADLINE_ISO=2026-05-15T23:59:59Z

# ===========================================
# Hotel 1 (leave blank to hide)
# ===========================================
NEXT_PUBLIC_HOTEL1_NAME=Hotel Recommendation 1
NEXT_PUBLIC_HOTEL1_ADDRESS=456 Hotel Ave, Austin, TX 78701
NEXT_PUBLIC_HOTEL1_PHONE=(512) 555-0101
NEXT_PUBLIC_HOTEL1_NOTES=Group rate available — mention the wedding when booking.
NEXT_PUBLIC_HOTEL1_BOOKING_URL=#

# ===========================================
# Hotel 2 (leave blank to hide)
# ===========================================
NEXT_PUBLIC_HOTEL2_NAME=Hotel Recommendation 2
NEXT_PUBLIC_HOTEL2_ADDRESS=789 Lodge Blvd, Austin, TX 78702
NEXT_PUBLIC_HOTEL2_PHONE=(512) 555-0102
NEXT_PUBLIC_HOTEL2_NOTES=10 minutes from venue. Free breakfast included.
NEXT_PUBLIC_HOTEL2_BOOKING_URL=#

# ===========================================
# Travel
# ===========================================
NEXT_PUBLIC_PARKING_INFO=Free parking is available at the venue lot.
NEXT_PUBLIC_DIRECTIONS=Directions to the venue from downtown.
